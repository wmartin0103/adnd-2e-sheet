  "weapon_proficiency_rules": {
    "proficiency_slots": "Each class receives an initial number of weapon proficiency slots and gains more at set intervals",
    "nonproficiency_penalty": {
      "warrior": -2,
      "priest":  -3,
      "rogue":   -3,
      "wizard":  -5
    },
    "specialization": {
      "description": "Fighters (and only fighters) may spend 2 proficiency slots on a single weapon to specialize",
      "benefits": {
        "melee_hit_bonus": "+1 to attack rolls",
        "melee_damage_bonus": "+2 to damage rolls",
        "extra_attacks_per_round": {
          "level_1_to_6":  "3/2 attacks per round",
          "level_7_to_12": "2/1 attacks per round",
          "level_13_plus": "5/2 attacks per round"
        },
        "missile_hit_bonus": "+1 to attack rolls",
        "missile_rate_of_fire": "Increased by 1 at certain levels"
      },
      "double_specialization": "An optional rule (DMG) allows spending 3 slots for additional bonuses"
    },
